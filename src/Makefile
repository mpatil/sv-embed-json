## File generated by the BNF Converter (bnfc 2.9.7).

SVLEX = ${LEXPATH}/lex
SVLEX_OPTS = -v

SVACC = ${YACCPATH}/svacc
SVACC_OPTS = -SVsemantic=svtype -v

QRUN = qrun
QRUN_OPTS = -64 -sv -mfcu -permissive -l comp.log -suppress 2875,2240 +incdir+./ +UVM_NO_RELNOTES
VCS = vcs
VCS_OPTS = -full64 -sverilog -l comp.log
VCS_SIM = lib_interp_json_0
TOPLEVEL = test
FUSESOC_RUN_DIR = lib_interp_json_0
TEST_VCS_DIR = ${FUSESOC_RUN_DIR}/test-vcs
SIM_SCRIPT = lib_interp_json_0.scr
TEST_INPUT = ../../test.json

.PHONY : all run qrun vcs clean distclean fusesoc

all : run

clean :
	rm -rf json/JSONParser.svh json/JSONLexer.svh qrun.out simv simv.daidir csrc ucli.key test-vcs ${FUSESOC_RUN_DIR}

distclean : clean
	rm -f json/JSONAbsyn.svh json/JSONAbsyn.sv json.l json.y json/JSONPrinter.sv json/JSONPrinter.svh json/JSONInterpBase.sv json/JSONInterpBase.svh Test.sv json/json_pkg.sv json/json.core comp.log vcs.log modelsim.ini json/*.bak y.output Makefile json.tex

json/JSONLexer.svh : json.l
	${SVLEX} ${SVLEX_OPTS} json.l
	mv lex.yy.v json/JSONLexer.svh

json/JSONParser.svh : json.y
	${SVACC} ${SVACC_OPTS} json.y
	mv Parser.svh json/JSONParser.svh
	cp ${YACCPATH}/bio.svh json

.PHONY: fusesoc
fusesoc : json/JSONParser.svh json/JSONLexer.svh
	fusesoc --cores-root json run --no-export --target=test --build-root=. --setup lib:interp:json

run : fusesoc Test.sv
	@if command -v ${QRUN} >/dev/null 2>&1; then \
	  ${MAKE} qrun; \
	elif command -v ${VCS} >/dev/null 2>&1; then \
	  ${MAKE} vcs; \
	else \
	  echo "Neither ${QRUN} nor ${VCS} found on PATH"; \
	  exit 127; \
	fi

.PHONY: qrun
qrun : fusesoc Test.sv
	cd ${TEST_VCS_DIR} && ${QRUN} ${QRUN_OPTS} -F ${SIM_SCRIPT} ../../../Test.sv +input=${TEST_INPUT}

.PHONY: vcs
vcs : fusesoc Test.sv
	cd ${TEST_VCS_DIR} && ${VCS} ${VCS_OPTS} +incdir+../.. -f ${SIM_SCRIPT} -top ${TOPLEVEL} -o ${VCS_SIM}
	cd ${TEST_VCS_DIR} && ./${VCS_SIM} -l vcs.log +input=${TEST_INPUT}
